# Site and form origin
# Use the production domain for production envs in Vercel.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
APP_URL=http://localhost:3000

# Optional extra trusted form origin. Same-origin submissions are allowed automatically.
ALLOWED_FORM_ORIGIN=http://localhost:3000

# Contact delivery provider
EMAIL_PROVIDER=console
CONTACT_EMAIL_TO=hello@philtinanosike.com
CONTACT_EMAIL_FROM=noreply@philtinanosike.com
RESEND_API_KEY=

# Newsletter capture provider
NEWSLETTER_PROVIDER=console
NEWSLETTER_LIST_ID=
CONVERTKIT_API_KEY=
BEEHIIV_API_KEY=
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
MAILCHIMP_SERVER_PREFIX=

# Rate limiting
# Keep `memory` for local development. Swap to a shared backing store for high-volume production traffic.
RATE_LIMIT_MODE=memory
RATE_LIMIT_WINDOW_MS=600000
CONTACT_RATE_LIMIT_MAX=5
NEWSLETTER_RATE_LIMIT_MAX=8
